    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^3.0.3",
    "bootstrap": "5.3.3",
    "next": "16.1.6",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "postmark": "^4.0.7",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/estree": "^1.0.9",
